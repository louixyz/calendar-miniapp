.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

/* 下一个假期卡片 */
.next-card {
  background: var(--color-primary);
  padding: 50rpx 40rpx;
  color: #fff;
  text-align: center;
}

.next-label {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
  margin-bottom: 8rpx;
}

.next-count {
  font-size: 96rpx;
  font-weight: 500;
  line-height: 1.1;
}

.next-unit {
  font-size: 28rpx;
  opacity: 0.8;
  margin-left: 4rpx;
}

.next-name {
  font-size: 32rpx;
  display: block;
  margin-top: 8rpx;
  font-weight: 500;
}

/* 年份导航 */
.year-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: var(--color-bg-card);
  margin-bottom: 20rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg-page);
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.year-text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin: 0 40rpx;
}

/* 假期列表 */
.holiday-list {
  padding: 0 20rpx 40rpx;
}

.holiday-card {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 20rpx;
}

.holiday-card.past {
  background: #f2f2f2;
}

.holiday-card.past .card-name,
.holiday-card.past .card-days,
.holiday-card.past .date-tag,
.holiday-card.past .workday-label,
.holiday-card.past .workday-date,
.holiday-card.past .countdown-text {
  color: #999999;
}

.holiday-card.past .card-days {
  background: #e8e8e8;
}

.holiday-card.past .tag-dot {
  background: #c6c6c6;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.card-days {
  font-size: 24rpx;
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.card-dates {
  margin-bottom: 12rpx;
}

.date-tag {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.tag-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.tag-dot.green {
  background: var(--color-solar-term);
}

.card-workdays {
  padding-top: 12rpx;
  border-top: 1rpx solid var(--color-border);
}

.workday-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.workday-date {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-left: 8rpx;
}

.card-countdown {
  margin-top: 12rpx;
  text-align: right;
}

.countdown-text {
  font-size: 22rpx;
  color: var(--color-primary);
}
