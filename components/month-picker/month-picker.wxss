.month-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.month-picker {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 30rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.arrow-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg-page);
}

.arrow-btn:active {
  background: var(--color-border);
}

.arrow-text {
  font-size: 32rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.year-text {
  font-size: 36rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin: 0 40rpx;
}

.month-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.month-item {
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-page);
}

.month-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 500;
}

.month-item:active {
  opacity: 0.8;
}

.back-today {
  text-align: center;
  padding: 20rpx 0;
  border-top: 1rpx solid var(--color-border);
}

.back-today-text {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: 500;
}
